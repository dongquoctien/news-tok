# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Generated data (projects + asset cache)
data/

# Local env
.env
.env.local
.env.*.local

# MCP config may carry user-specific API keys; keep it out of git.
.mcp.json

# Render outputs (kept under data/ but also catch stray files)
*.mp4
*.mp3
*.wav

# Keep the bundled SFX bank in git — those are intentionally committed
# so renders are deterministic and offline. Each clip is < 5 KB.
!packages/shared/sfx/*.mp3

# IDE / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test
coverage/

# Verify screenshots (chrome-devtools MCP)
.verify/

# Remotion bundle cache and generated entry files
.remotion-cache/
.entry-cache/
