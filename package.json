{
  "name": "news-tok",
  "version": "0.0.1",
  "private": true,
  "description": "Convert articles/text/URLs into short videos using Claude CLI as orchestrator and Remotion for render.",
  "license": "MIT",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "studio": "pnpm --filter @news-tok/studio dev",
    "mcp:build": "pnpm --filter @news-tok/mcp-server build",
    "doctor": "node scripts/doctor.mjs",
    "smoke:render": "tsx scripts/smoke-render.ts",
    "smoke:media": "tsx scripts/smoke-media.ts",
    "smoke:media:network": "tsx scripts/smoke-media-network.ts",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "smoke:m6": "tsx scripts/smoke-m6.ts"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
