# Pexels API key — https://www.pexels.com/api/
# Primary image source. Stable from Node.
PEXELS_API_KEY=

# Unsplash Access Key — https://unsplash.com/oauth/applications
# Image fallback when Pexels has no match. Heroku-hosted, no Cloudflare.
UNSPLASH_ACCESS_KEY=

# Pixabay API key — https://pixabay.com/api/docs/
# Optional. Image API works (with retry/UA rotation against Cloudflare).
# NOTE: Pixabay's music API endpoint (/api/music/) returns 404 — deprecated.
# Use Internet Archive (provider="archive") for music instead.
PIXABAY_API_KEY=

# Internet Archive (https://archive.org) does NOT require an API key.
# Music adapter uses it as the default provider.

# DO NOT SET ANTHROPIC_API_KEY HERE.
# This project uses your Claude Pro/Max subscription via `claude login`.
# Setting ANTHROPIC_API_KEY would switch Claude CLI to API per-token billing.
